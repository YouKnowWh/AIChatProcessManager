# Database URL (for SQLAlchemy)
DATABASE_URL=mysql+pymysql://aichat_user:aichat_password@localhost:3306/aichat_db?charset=utf8mb4

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-api-key-here
